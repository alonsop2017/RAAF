# ── RAAF Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# Required: Google OAuth
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-here

# Required: Session signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=your-random-secret-key-here

# Required: Anthropic Claude API key (for AI assessments)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Set to "1" to bypass authentication (development only — never in production)
# DEV_MODE=0

# ── Google Drive Backup (for raaf-data-init container) ──────────────────────
# rclone remote name and path where backups are stored.
# Run `rclone config` on the host to set up the remote, then ensure
# ~/.config/rclone/rclone.conf is mounted into the raaf-data-init container.
GDRIVE_REMOTE=raaf-backup:RAAF-Backups

# Set to "true" to force re-download and overwrite existing data on next `docker compose up`.
# Useful for restoring from a specific backup. Reset to "false" after use.
FORCE_RESTORE=false
